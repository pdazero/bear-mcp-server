# === Database ===
# Path to Bear's SQLite database (auto-detected if not set)
# BEAR_DATABASE_PATH=~/Library/Group Containers/9K33E3U3T4.net.shinyfrog.bear/Application Data/database.sqlite

# === Embedding Presets ===
# Choose a preset: light (built-in), medium, or heavy (require local inference server)
# EMBEDDING_PRESET=light
# Backend for medium/heavy presets: lmstudio or ollama
# EMBEDDING_BACKEND=lmstudio

# === Custom Embedding (overrides preset) ===
# Set EMBEDDING_PROVIDER to fully override the preset system
# EMBEDDING_PROVIDER=transformers|ollama|lmstudio|openai-compat
# EMBEDDING_MODEL=model-name
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_BASE_URL=http://localhost:1234
# EMBEDDING_API_KEY=
# EMBEDDING_INSTRUCTION_PREFIX=

# === Auto-Indexing ===
# Keep the vector index up to date automatically (requires initial npm run index)
# AUTO_INDEX_ENABLED=false
# AUTO_INDEX_INTERVAL_SECONDS=300

# === Storage & Logging ===
# DATA_DIR=data
# LOG_LEVEL=info
