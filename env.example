# Bear database path (optional, uses default macOS path if not set)
# BEAR_DATABASE_PATH=~/Library/Group Containers/9K33E3U3T4.net.shinyfrog.bear/Application Data/database.sqlite

# Embedding preset: light (default), medium, heavy
# EMBEDDING_PRESET=light

# Or custom provider configuration (overrides preset):
# EMBEDDING_PROVIDER=ollama|lmstudio|openai-compat|transformers
# EMBEDDING_MODEL=model-name
# EMBEDDING_DIMENSIONS=384
# EMBEDDING_BASE_URL=http://localhost:11434
# EMBEDDING_API_KEY=your-api-key
# EMBEDDING_INSTRUCTION_PREFIX=

# Backend for medium/heavy presets (default: lmstudio)
# EMBEDDING_BACKEND=lmstudio

# Data directory for vector index (default: data)
# DATA_DIR=data

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
